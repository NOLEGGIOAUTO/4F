{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/send-quote",
      "destination": "/api/send-quote.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|assets/|images/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
